{
  "name": "automation",
  "version": "1.0.0",
  "status": "production",
  "coverage": 80,
  "description": "Automation rule builder with event triggers and conditions",

  "components": {
    "AutomationRuleForm": {
      "path": "components/AutomationRuleForm.tsx",
      "type": "form",
      "description": "Main form for creating/editing automation rules"
    },
    "TriggerBuilder": {
      "path": "components/TriggerBuilder.tsx",
      "type": "builder",
      "description": "Event/schedule trigger configuration component"
    },
    "ConditionBuilder": {
      "path": "components/ConditionBuilder.tsx",
      "type": "builder",
      "description": "Rule condition configuration with AND/OR logic"
    },
    "ActionBuilder": {
      "path": "components/ActionBuilder.tsx",
      "type": "builder",
      "description": "Action configuration (notifications, webhooks, events)"
    },
    "AutomationRuleList": {
      "path": "components/AutomationRuleList.tsx",
      "type": "list",
      "description": "Table view of automation rules with actions"
    },
    "AutomationExecutionList": {
      "path": "components/AutomationExecutionList.tsx",
      "type": "list",
      "description": "Execution history viewer for rules"
    }
  },

  "pages": {
    "AutomationPage": {
      "path": "routes/automation.tsx",
      "description": "Main automation management hub with tabs"
    }
  },

  "hooks": {
    "useAutomationRules": "List automation rules with pagination",
    "useCreateAutomationRule": "Create new rule mutation",
    "useUpdateAutomationRule": "Update rule mutation",
    "useDeleteAutomationRule": "Delete rule mutation",
    "useExecuteAutomationRule": "Execute rule manually",
    "useEnableAutomationRule": "Enable/disable rule",
    "useCloneAutomationRule": "Clone existing rule"
  },

  "types": {
    "AutomationRule": "Complete rule definition",
    "AutomationTrigger": "Event or schedule trigger",
    "AutomationCondition": "Field-based condition with operators",
    "AutomationAction": "Action to execute (notification, webhook, etc)",
    "AutomationExecution": "Rule execution record"
  },

  "api": {
    "endpoints": [
      "POST /api/v1/automation/rules",
      "GET /api/v1/automation/rules",
      "GET /api/v1/automation/rules/{id}",
      "PUT /api/v1/automation/rules/{id}",
      "DELETE /api/v1/automation/rules/{id}",
      "POST /api/v1/automation/rules/{id}/execute",
      "GET /api/v1/automation/rules/{id}/executions"
    ]
  },

  "builders": {
    "TriggerBuilder": {
      "types": ["event", "schedule", "manual"],
      "triggers": ["task.assigned", "file.uploaded", "user.created"]
    },
    "ConditionBuilder": {
      "operators": [
        "eq",
        "ne",
        "gt",
        "lt",
        "gte",
        "lte",
        "in",
        "nin",
        "contains",
        "not_contains"
      ],
      "logicalOperators": ["and", "or"]
    },
    "ActionBuilder": {
      "actionTypes": [
        "send_notification",
        "create_task",
        "update_entity",
        "send_webhook",
        "publish_event"
      ],
      "channels": ["email", "sms", "in-app", "webhook"]
    }
  },

  "i18n": {
    "languages": ["en", "es"],
    "keys": 60,
    "coverage": "100%"
  },

  "tests": {
    "unit": [
      "TriggerBuilder.test.tsx",
      "ConditionBuilder.test.tsx",
      "ActionBuilder.test.tsx"
    ],
    "coverage": "80%",
    "status": "passing"
  },

  "refactoring": {
    "improvements": [
      "Extracted 3 builder components from form (545 → 210 lines)",
      "Improved separation of concerns",
      "Increased code reusability",
      "Better testability"
    ],
    "codeReduction": "61% in AutomationRuleForm"
  }
}
