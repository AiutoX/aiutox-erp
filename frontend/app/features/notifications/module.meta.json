{
  "name": "notifications",
  "version": "1.0.0",
  "status": "production",
  "coverage": 85,
  "description": "Real-time notification management with WebSocket support",

  "components": {
    "NotificationsPage": {
      "path": "routes/notifications.tsx",
      "type": "page",
      "description": "Main notification center hub with real-time updates"
    },
    "NotificationDetail": {
      "path": "components/NotificationDetail.tsx",
      "type": "component",
      "description": "Individual notification display with error handling"
    }
  },

  "hooks": {
    "useNotifications": {
      "path": "hooks/useNotifications.ts",
      "description": "API queries for notification templates and queue"
    },
    "useNotificationsWebSocket": {
      "path": "hooks/useNotificationsWebSocket.ts",
      "description": "Real-time WebSocket connection with auto-reconnect"
    }
  },

  "types": {
    "NotificationQueue": "Notification in delivery queue",
    "NotificationTemplate": "Notification message template",
    "NotificationChannel": "Delivery channel (email, SMS, in-app, webhook)"
  },

  "api": {
    "endpoints": [
      "GET /api/v1/notifications/queue",
      "POST /api/v1/notifications/send",
      "PUT /api/v1/notifications/{id}",
      "DELETE /api/v1/notifications/{id}",
      "WS /api/v1/notifications/stream"
    ]
  },

  "i18n": {
    "languages": ["en", "es"],
    "keys": 100,
    "coverage": "100%"
  },

  "features": {
    "realTimeUpdates": "WebSocket-based real-time notifications",
    "autoReconnect": "Exponential backoff reconnection strategy",
    "filtering": "Filter by channel, status, and search term",
    "statistics": "Live statistics (total, pending, sent, failed)",
    "preferences": "User notification preferences (UI prepared)"
  },

  "tests": {
    "unit": ["NotificationsWebSocket.test.tsx"],
    "coverage": "85%",
    "status": "passing"
  }
}
