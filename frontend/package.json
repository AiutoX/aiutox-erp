{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npx tsx scripts/link-external-features.ts",
    "generate-routes": "npx tsx scripts/generate-routes.ts",
    "prebuild": "npx tsx scripts/generate-routes.ts",
    "build": "npx react-router build",
    "dev": "react-router dev",
    "start": "npx vite preview --port 3000 --host 0.0.0.0",
    "typecheck": "react-router typegen && tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "generate-types": "node scripts/generate-event-types.mjs",
    "validate": "npm run typecheck && npm run lint:strict && npm run format:check",
    "validate:fix": "npm run typecheck && npm run lint:fix && npm run format",
    "prepare": "husky",
    "test": "node scripts/test-ci.mjs",
    "test:watch": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:parallel": "vitest run --threads=4",
    "test:windows": "vitest run --no-coverage --reporter=verbose",
    "test:windows:hooks": "vitest run --no-coverage --reporter=verbose app/hooks/__tests__",
    "test:windows:features": "vitest run --no-coverage --reporter=verbose app/features/**/__tests__",
    "test:windows:routes": "vitest run --no-coverage --reporter=verbose app/routes/__tests__",
    "test:windows:components": "vitest run --no-coverage --reporter=verbose app/components/**/__tests__",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:parallel": "playwright test  --project=chromium --workers=4 --headed --max-failures=1 --reporter=line",
    "test:e2e:theme": "playwright test app/__tests__/e2e/config/theme-config-e2e.spec.ts --project=chromium --workers=4 --headed --max-failures=1 --reporter=line",
    "test:theme:all": "npm run test:run -- app/hooks/__tests__/useThemeConfig.test.ts app/routes/__tests__/config.theme.test.tsx app/__tests__/integration/config/theme-api.test.ts && npm run test:e2e:theme",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:upload": "lhci upload",
    "lighthouse:report": "lhci report"
  },
